{
  "name": "broflip",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,sock -c blue,magenta \"next dev\" \"npm run dev:server\"",
    "dev:next": "next dev",
    "dev:server": "tsx watch server/index.ts",
    "build": "next build",
    "start": "concurrently -n next,sock -c blue,magenta \"next start\" \"npm run start:server\"",
    "start:server": "NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.98.4",
    "bcryptjs": "^3.0.3",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "ed25519-hd-key": "^2.0.0",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tweetnacl": "^1.0.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
