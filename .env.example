# Neon pooled connection string (host contains "-pooler"). Required.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional in dev (Auth.js infers from request); required in production.
# AUTH_URL=http://localhost:3000

# --- Solana custody ------------------------------------------------------
# Master BIP39 mnemonic. EVERY wallet on the platform — house + every user
# deposit address — derives from this. Treat it like a database password
# made of fire. For production, get this out of env and into an HSM /
# threshold signer (Fireblocks, Turnkey, Privy).
#
# Generate one in any BIP39 tool, or:
#   solana-keygen new -o /tmp/x.json --no-bip39-passphrase --silent
# (the resulting JSON file's `seed` is the BIP39 mnemonic.)
SOLANA_MNEMONIC="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# RPC endpoint. Default is Solana's public devnet — fine for dev, rate
# limited. Production: a paid RPC (Helius, QuickNode, Triton).
SOLANA_RPC_URL=https://api.devnet.solana.com

# Mirror of SOLANA_RPC_URL exposed to the browser. Used by the wallet-adapter
# `ConnectionProvider` so client-side balance reads / tx submits hit the same
# endpoint the server uses.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Fixed price used for ledger conversion. Production: replace with a Pyth
# / Switchboard oracle read. MVP keeps it constant for predictability.
SOL_USD_PRICE=200

# --- Google OAuth (optional) ---------------------------------------------
# To enable the "Continue with Google" button:
#   1. https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth client ID, type "Web application"
#   3. Authorized redirect URI:
#        http://localhost:3000/api/auth/callback/google   (dev)
#        https://your-domain/api/auth/callback/google     (prod)
#   4. Set the two vars below + flip the public flag so the modal shows the
#      button. Without these the modal just shows "not configured".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_ENABLED=false
